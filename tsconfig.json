{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "noEmit": true
  },
  "include": ["db/**/*.ts", "api/**/*.ts", "drizzle.config.ts"],
  "exclude": ["node_modules", "dist", "src"]
}
