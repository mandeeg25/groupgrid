# Copy to .env.local and fill in real values. Never commit actual secrets.

# ── Client-side (VITE_ prefix = bundled into the browser build) ──────────────
# Publishable/anon key only — never the secret key.
VITE_SUPABASE_URL=
VITE_SUPABASE_KEY=

# ── Server-only (never prefix with VITE_, never reference from client code) ──
# Postgres connection for Drizzle, via Supabase's transaction-mode pooler (port 6543).
DATABASE_URL=
# Elevated Supabase access — only if a backend function needs to bypass RLS.
SUPABASE_SECRET_KEY=
SUPABASE_JWKS_URL=

# ── Stripe (added once the Stripe backend work lands — see docs/stripe-backend-plan.md) ──
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
